kgf 0.6
language: elixir
sources: .ex, .exs

=== lex
SKIP /[ \t]+/
TOKEN NL /\r?\n/

# Comments
TOKEN Comment /#[^\r\n]*/

# Documentation attributes
TOKEN DocAttr /@(doc|moduledoc|typedoc)\s+(~[sSwwcCaA])?"""[\s\S]*?"""|@(doc|moduledoc|typedoc)\s+false/
TOKEN ModuleAttr /@[a-zA-Z_][a-zA-Z0-9_]*/

# String literals
TOKEN String /"([^"\\]|\\.)*"|'([^'\\]|\\.)*'|~[sSwwcCaA]?"""[\s\S]*?"""|~[sSwwcCaA]?"([^"\\]|\\.)*"|~[sSwwcCaA]?'([^'\\]|\\.)*'/

# Atoms
TOKEN Atom /:[a-zA-Z_][a-zA-Z0-9_@]*|:"([^"\\]|\\.)*"/

# Numeric literals
TOKEN Number /0x[0-9a-fA-F_]+|0b[01_]+|0o[0-7_]+|[0-9][0-9_]*(\.[0-9_]+)?([eE][+-]?[0-9_]+)?/

# Keywords
KEYWORD KW_defmodule /defmodule\b/
KEYWORD KW_defprotocol /defprotocol\b/
KEYWORD KW_defimpl /defimpl\b/
KEYWORD KW_defstruct /defstruct\b/
KEYWORD KW_defexception /defexception\b/
KEYWORD KW_defmacro /defmacro\b/
KEYWORD KW_defmacrop /defmacrop\b/
KEYWORD KW_defguard /defguard\b/
KEYWORD KW_defguardp /defguardp\b/
KEYWORD KW_def /def\b/
KEYWORD KW_defp /defp\b/
KEYWORD KW_defdelegate /defdelegate\b/
KEYWORD KW_if /if\b/
KEYWORD KW_unless /unless\b/
KEYWORD KW_case /case\b/
KEYWORD KW_cond /cond\b/
KEYWORD KW_with /with\b/
KEYWORD KW_for /for\b/
KEYWORD KW_try /try\b/
KEYWORD KW_receive /receive\b/
KEYWORD KW_after /after\b/
KEYWORD KW_rescue /rescue\b/
KEYWORD KW_catch /catch\b/
KEYWORD KW_else /else\b/
KEYWORD KW_end /end\b/
KEYWORD KW_do /do\b/
KEYWORD KW_fn /fn\b/
KEYWORD KW_raise /raise\b/
KEYWORD KW_require /require\b/
KEYWORD KW_import /import\b/
KEYWORD KW_alias /alias\b/
KEYWORD KW_use /use\b/
KEYWORD KW_when /when\b/

# Built-in values
TOKEN BoolLit /\b(?:true|false)\b/
TOKEN NilLit /\bnil\b/

# Identifiers
TOKEN ModuleIdent /[A-Z][a-zA-Z0-9_]*/
TOKEN Ident /[a-z_][a-zA-Z0-9_]*[?!]?/

# Operators
TOKEN PIPE    /\|>/
TOKEN ARROW   /->/
TOKEN LARROW  /<-/
TOKEN DARROW  /=>/
TOKEN Operator /[+\-*\/%&|^~!<>=]+|&&|\|\||<>|\\\\|\+\+|--|\.\.\.?|::|\^\^/

# Punctuation
TOKEN LBRACE   /\{/
TOKEN RBRACE   /\}/
TOKEN LPAREN   /\(/
TOKEN RPAREN   /\)/
TOKEN LBRACKET /\[/
TOKEN RBRACKET /\]/
TOKEN SEMI     /;/
TOKEN COMMA    /,/
TOKEN DOT      /\./
TOKEN COLON    /:/
TOKEN AT       /@/

=== grammar
Module -> Item*

Item -> NL
     / Comment
     / DocAttr
     / ModuleDecl
     / ProtocolDecl
     / ImplDecl
     / DefDecl
     / DefMacroDecl
     / DefGuardDecl
     / UseDecl
     / ImportDecl
     / AliasDecl
     / RequireDecl
     / Other

# Module declaration
ModuleDecl -> doc:DocAttr? NL? KW_defmodule id:ModulePath ( KW_do ModuleBody KW_end / COMMA KW_do COLON ModuleBody )
ModulePath -> ModuleIdent ( DOT ModuleIdent )*
ModuleBody -> ( ModuleMember )*
ModuleMember -> DocAttr / ModuleAttr / DefDecl / DefMacroDecl / DefGuardDecl / StructDecl / UseDecl / ImportDecl / AliasDecl / RequireDecl / ModuleDecl / NL / Comment

# Protocol declaration
ProtocolDecl -> doc:DocAttr? NL? KW_defprotocol id:ModulePath ( KW_do ProtocolBody KW_end / COMMA KW_do COLON ProtocolBody )
ProtocolBody -> ( ProtocolMember )*
ProtocolMember -> DocAttr / DefDecl / NL / Comment

# Impl declaration
ImplDecl -> doc:DocAttr? NL? KW_defimpl ModulePath COMMA KW_for COLON ModulePath ( KW_do ImplBody KW_end / COMMA KW_do COLON ImplBody )
ImplBody -> ( ImplMember )*
ImplMember -> DocAttr / DefDecl / NL / Comment

# Struct declaration
StructDecl -> KW_defstruct LBRACKET ( StructField ( COMMA StructField )* )? RBRACKET
StructField -> Atom / Ident / LBRACE Atom COMMA Expr RBRACE

# Def declaration
DefDecl -> doc:DocAttr? NL? vis:( KW_def / KW_defp ) def_id:Ident DefArgs? ( KW_when Expr )? ( KW_do DefBody KW_end / COMMA KW_do COLON Expr )
DefArgs -> LPAREN ParamList? RPAREN
DefBody -> ( DefContent )*
DefContent -> NL / Comment / Expr / Statement

# DefMacro declaration
DefMacroDecl -> doc:DocAttr? NL? vis:( KW_defmacro / KW_defmacrop ) macro_id:Ident DefArgs? ( KW_when Expr )? ( KW_do DefBody KW_end / COMMA KW_do COLON Expr )

# DefGuard declaration
DefGuardDecl -> doc:DocAttr? NL? vis:( KW_defguard / KW_defguardp ) guard_id:Ident DefArgs? ( KW_when Expr )?

# Use/Import/Alias/Require
UseDecl -> KW_use ModulePath ( COMMA Expr )*
ImportDecl -> KW_import path:ModulePath ( COMMA Expr )*
AliasDecl -> KW_alias ModulePath ( COMMA Expr )*
RequireDecl -> KW_require ModulePath ( COMMA Expr )*

# Parameters
ParamList -> Param ( COMMA Param )*
Param -> param_id:Ident ( Operator Ident )? ( Operator Expr )?

# Statement
Statement -> KW_if / KW_unless / KW_case / KW_cond / KW_with / KW_for / KW_try / KW_receive / KW_after / KW_rescue / KW_catch / KW_else / KW_end / KW_do / KW_fn / KW_raise / KW_when

# Expressions
Expr -> ExprAtom+
ExprAtom -> Ident / ModuleIdent / Number / String / Atom / BoolLit / NilLit / LPAREN / RPAREN / LBRACE / RBRACE / LBRACKET / RBRACKET / DOT / COMMA / COLON / PIPE / ARROW / LARROW / DARROW / Operator / ModuleAttr / DocAttr

Atom2 -> ExprAtom / NL / Comment / KW_defmodule / KW_defprotocol / KW_defimpl / KW_defstruct / KW_defexception / KW_defmacro / KW_defmacrop / KW_defguard / KW_def / KW_defp / KW_defdelegate / KW_if / KW_unless / KW_case / KW_cond / KW_with / KW_for / KW_try / KW_receive / KW_after / KW_rescue / KW_catch / KW_else / KW_end / KW_do / KW_fn / KW_raise / KW_require / KW_import / KW_alias / KW_use / KW_when / SEMI / AT

Other -> Atom2

=== attrs
on ModuleDecl:    def id kind=Module doc=doc
on ProtocolDecl:  def id kind=Protocol doc=doc
on DefDecl:       def def_id kind=Function doc=doc
on DefMacroDecl:  def macro_id kind=Macro doc=doc
on DefGuardDecl:  def guard_id kind=Guard doc=doc
on Param:         def param_id kind=Param

on ImportDecl:    import module=path

=== features
function_kinds: Function, Guard, Macro
function_keyword: KW_def
identifier_kinds: Ident, ModuleIdent
qualifier_separators: DOT
vocabulary_token_kinds: DocAttr, String

=== semantics
# Import dependency
on ImportDecl {
  edge moduleDependsOn from $file to $resolve($path) attrs obj("via", $path, "dep_kind", "value")
}

# Elixir public declarations
on ModuleDecl {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Module", "doc", $doc)
}
on ProtocolDecl {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Protocol", "doc", $doc)
}

# def = public, defp = private
on DefDecl when eq($vis, "def") {
  edge declares from $file to concat($file, "::", $def_id) attrs obj("name", $def_id, "kind", "Function", "doc", $doc)
}
on DefMacroDecl when eq($vis, "defmacro") {
  edge declares from $file to concat($file, "::", $macro_id) attrs obj("name", $macro_id, "kind", "Macro", "doc", $doc)
}
on DefGuardDecl when eq($vis, "defguard") {
  edge declares from $file to concat($file, "::", $guard_id) attrs obj("name", $guard_id, "kind", "Guard", "doc", $doc)
}

# Def in module
on DefDecl when $scope("value", "current_module") {
  let parent = $scope("value", "current_module")
  let sym_id = concat(parent, ".", $def_id)
  edge declares from parent to sym_id attrs obj("name", $def_id, "kind", "Function", "doc", $doc)
}

=== resolver
relative_prefixes: ./
module_path_style: dot
resolve:
  - manifest: mix.exs @ deps
  - marker: mix.exs
  - ext: .ex, .exs
  - fallback: hex:
