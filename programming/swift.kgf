kgf 0.6
language: swift
sources: .swift

=== lex
SKIP /[ \t]+/
TOKEN NL /\r?\n/

# Comments - Swift uses /// for documentation
TOKEN DocComment /\/\/\/(.*)/
TOKEN DocBlockComment /\/\*\*([\s\S]*?)\*\//
TOKEN LineComment /\/\/[^\r\n]*/
TOKEN BlockComment /\/\*[\s\S]*?\*\//

# String literals
TOKEN String /"([^"\\]|\\.)*"|#"[^"]*"#|"""[\s\S]*?"""/

# Numeric literals
TOKEN Number /0x[0-9a-fA-F_]+|0b[01_]+|0o[0-7_]+|[0-9][0-9_]*(\.[0-9_]+)?([eE][+-]?[0-9_]+)?/

# Attributes
TOKEN Attribute /@[a-zA-Z_][a-zA-Z0-9_]*/

# Keywords
KEYWORD KW_import     /import\b/
KEYWORD KW_let        /let\b/
KEYWORD KW_var        /var\b/
KEYWORD KW_func       /func\b/
KEYWORD KW_class      /class\b/
KEYWORD KW_struct     /struct\b/
KEYWORD KW_enum       /enum\b/
KEYWORD KW_protocol   /protocol\b/
KEYWORD KW_extension  /extension\b/
KEYWORD KW_typealias  /typealias\b/
KEYWORD KW_actor      /actor\b/
KEYWORD KW_init       /init\b/
KEYWORD KW_deinit     /deinit\b/
KEYWORD KW_subscript  /subscript\b/
KEYWORD KW_public     /public\b/
KEYWORD KW_private    /private\b/
KEYWORD KW_internal   /internal\b/
KEYWORD KW_fileprivate /fileprivate\b/
KEYWORD KW_open       /open\b/
KEYWORD KW_final      /final\b/
KEYWORD KW_static     /static\b/
KEYWORD KW_override   /override\b/
KEYWORD KW_mutating   /mutating\b/
KEYWORD KW_async      /async\b/
KEYWORD KW_await      /await\b/
KEYWORD KW_throws     /throws\b/
KEYWORD KW_if         /if\b/
KEYWORD KW_else       /else\b/
KEYWORD KW_guard      /guard\b/
KEYWORD KW_switch     /switch\b/
KEYWORD KW_case       /case\b/
KEYWORD KW_for        /for\b/
KEYWORD KW_in         /in\b/
KEYWORD KW_while      /while\b/
KEYWORD KW_return     /return\b/
KEYWORD KW_where      /where\b/
KEYWORD KW_self       /self\b/
KEYWORD KW_Self       /Self\b/

# Built-in values
TOKEN BoolLit /\b(?:true|false)\b/
TOKEN NilLit /\bnil\b/

# Identifiers
TOKEN TypeIdent /[A-Z][a-zA-Z0-9_]*/
TOKEN Ident /[a-z_][a-zA-Z0-9_]*/

# Operators
TOKEN ARROW   /->/
TOKEN LT       /</
TOKEN GT       />/
TOKEN Operator /[+\-*%&|^~!=]+|&&|\|\||\.\.\.|\.\.</

# Punctuation
TOKEN LBRACE   /\{/
TOKEN RBRACE   /\}/
TOKEN LPAREN   /\(/
TOKEN RPAREN   /\)/
TOKEN LBRACKET /\[/
TOKEN RBRACKET /\]/
TOKEN SEMI     /;/
TOKEN COMMA    /,/
TOKEN DOT      /\./
TOKEN COLON    /:/
TOKEN QMARK    /\?/
TOKEN AT       /@/

# Property accessors (referenced in grammar)
KEYWORD KW_get    /get\b/
KEYWORD KW_set    /set\b/

=== grammar
Module -> Item*

Item -> NL
     / ImportDecl
     / ClassDecl
     / StructDecl
     / EnumDecl
     / ProtocolDecl
     / ExtensionDecl
     / ActorDecl
     / FuncDecl
     / VarDecl
     / TypeAliasDecl
     / DocComment
     / DocBlockComment
     / Other

# Doc block (consecutive /// comments)
DocBlock -> DocComment ( NL DocComment )* / DocBlockComment

# Import declaration
ImportDecl -> KW_import path:QualifiedName
QualifiedName -> ( Ident / TypeIdent ) ( DOT ( Ident / TypeIdent ) )*

# Class declaration
ClassDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_class id:TypeIdent SimpleInheritance? LBRACE ClassMember* RBRACE
InheritanceClause -> COLON TypeList
ClassBody -> LBRACE ClassMember* RBRACE
ClassMember -> FuncDecl / VarDecl / InitDecl / DeinitDecl / SubscriptDecl / ClassDecl / StructDecl / EnumDecl / TypeAliasDecl / NL / LineComment / BlockComment

# Struct declaration
StructDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_struct id:TypeIdent TypeParams? SimpleInheritance? LBRACE StructMember* RBRACE
SimpleInheritance -> COLON TypeIdent COMMA TypeIdent COMMA TypeIdent / COLON TypeIdent COMMA TypeIdent / COLON TypeIdent
StructMember -> FuncDecl / VarDecl / InitDecl / SubscriptDecl / TypeAliasDecl / NL / LineComment / BlockComment

# Enum declaration
EnumDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_enum id:TypeIdent TypeParams? InheritanceClause? WhereClause? EnumBody
EnumBody -> LBRACE EnumMember* RBRACE
EnumMember -> EnumCase / FuncDecl / VarDecl / InitDecl / SubscriptDecl / TypeAliasDecl / NL / LineComment / BlockComment
EnumCase -> case_doc:DocBlock? Attribute* KW_case case_id:CaseName AssociatedValues? RawValue? ( COMMA case_id:CaseName AssociatedValues? RawValue? )*

# Enum case names: lower-camel by Swift convention but PascalCase is legal,
# and case bodies may need to escape keywords with backticks. Accept the
# union of identifier classes; backtick-escaped forms are tokenized
# separately by `BacktickIdent` if the lexer supports it, else they remain
# a syntactic gap to fix per-target.
CaseName -> Ident / TypeIdent
AssociatedValues -> LPAREN ParamList? RPAREN
RawValue -> Operator Expr

# Protocol declaration
ProtocolDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_protocol id:TypeIdent InheritanceClause? WhereClause? ProtocolBody
ProtocolBody -> LBRACE ProtocolMember* RBRACE
ProtocolMember -> FuncDecl / VarDecl / InitDecl / SubscriptDecl / AssociatedType / NL / LineComment / BlockComment
AssociatedType -> assoc_doc:DocBlock? Attribute* KW_typealias assoc_id:TypeIdent ( COLON Type )? WhereClause?

# Extension declaration
ExtensionDecl -> doc:DocBlock? NL? Attribute* Modifier* KW_extension Type InheritanceClause? WhereClause? ExtensionBody
ExtensionBody -> LBRACE ExtensionMember* RBRACE
ExtensionMember -> FuncDecl / VarDecl / InitDecl / SubscriptDecl / TypeAliasDecl / ClassDecl / StructDecl / EnumDecl / NL / LineComment / BlockComment

# Actor declaration
ActorDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_actor id:TypeIdent TypeParams? InheritanceClause? WhereClause? ClassBody

# Function declaration
FuncDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_func id:Ident TypeParams? LPAREN ParamList? RPAREN ( KW_throws / KW_async KW_throws? )? ( ARROW Type )? WhereClause? Body?

# Variable declaration
VarDecl -> doc:DocBlock? NL? Attribute* Modifier* ( KW_let / KW_var ) id:Ident ( COLON Type )? ( Operator Expr )? Accessors?
Accessors -> LBRACE Accessor+ RBRACE
Accessor -> Attribute* Modifier* ( Ident / KW_get / KW_set ) Body?

# Init declaration
InitDecl -> doc:DocBlock? NL? Attribute* Modifier* KW_init ( Operator / LPAREN ParamList? RPAREN ) ( KW_throws )? Body?

# Deinit declaration
DeinitDecl -> doc:DocBlock? NL? KW_deinit Body

# Subscript declaration
SubscriptDecl -> doc:DocBlock? NL? Attribute* Modifier* KW_subscript TypeParams? LPAREN ParamList? RPAREN ARROW Type WhereClause? Accessors

# Type alias
TypeAliasDecl -> doc:DocBlock? NL? Attribute* vis:Visibility? Modifier* KW_typealias id:TypeIdent TypeParams? Operator Type

# Visibility (public or open = externally visible)
Visibility -> KW_public LPAREN KW_set RPAREN / KW_open / KW_public
# Modifiers
Modifier -> Visibility / KW_private LPAREN KW_set RPAREN / KW_internal LPAREN KW_set RPAREN / KW_fileprivate LPAREN KW_set RPAREN / KW_private / KW_internal / KW_fileprivate / KW_final / KW_static / KW_override / KW_mutating / KW_async

# Parameters
ParamList -> Param ( COMMA Param )*
Param -> Attribute* ( Ident param_id:Ident / param_id:Ident ) COLON Type ( Operator Expr )?
WhereClause -> KW_where WhereConstraint ( COMMA WhereConstraint )*
WhereConstraint -> Type ( COLON / Operator ) Type

# Types
TypeParams -> LT TypeParam ( COMMA TypeParam )* GT
TypeParam -> TypeIdent ( COLON Type )?
TypeList -> Type ( COMMA Type )*
Type -> TypeAtom ( Operator TypeAtom )* QMARK?
TypeAtom -> TypeIdent TypeArgs? / Ident / LBRACKET Type ( COLON Type )? RBRACKET / LPAREN TypeList? RPAREN ( ARROW Type )?
TypeArgs -> LT Type ( COMMA Type )* GT
# Body (simplified - balance braces)
Body -> LBRACE BodyContent* RBRACE
BodyContent -> LBRACE BodyContent* RBRACE / LPAREN BodyContent* RPAREN / LBRACKET BodyContent* RBRACKET / Atom

# Expressions
Expr -> ( ExprAtom / LBRACKET Expr? RBRACKET )+
ExprAtom -> Ident / TypeIdent / Number / String / BoolLit / NilLit / KW_self / KW_Self / LPAREN / RPAREN / DOT / COMMA / COLON / ARROW / LT / GT / Operator / Attribute

Atom -> Ident / TypeIdent / Number / String / BoolLit / NilLit / NL / DocComment / DocBlockComment / LineComment / BlockComment / KW_import / KW_let / KW_var / KW_func / KW_class / KW_struct / KW_enum / KW_protocol / KW_extension / KW_typealias / KW_actor / KW_init / KW_deinit / KW_subscript / KW_public / KW_private / KW_internal / KW_fileprivate / KW_open / KW_final / KW_static / KW_override / KW_mutating / KW_async / KW_await / KW_throws / KW_if / KW_else / KW_guard / KW_switch / KW_case / KW_for / KW_in / KW_while / KW_return / KW_where / KW_self / KW_Self / KW_get / KW_set / SEMI / COMMA / COLON / DOT / ARROW / QMARK / LT / GT / Operator / Attribute / AT

Other -> Atom

=== attrs
on ClassDecl:     def id kind=Class doc=doc
on StructDecl:    def id kind=Struct doc=doc
on EnumDecl:      def id kind=Enum doc=doc
on ProtocolDecl:  def id kind=Protocol doc=doc
on ActorDecl:     def id kind=Actor doc=doc
on FuncDecl:      def id kind=Function doc=doc
on VarDecl:       def id kind=Variable doc=doc
on TypeAliasDecl: def id kind=TypeAlias doc=doc
on EnumCase:      def case_id kind=EnumCase doc=case_doc
on AssociatedType: def assoc_id kind=AssociatedType doc=assoc_doc
on Param:         def param_id kind=Param

on ImportDecl:    import module=path

=== features
function_kinds: Function
function_keyword: KW_func
identifier_kinds: Ident, TypeIdent
self_keyword: KW_self
qualifier_separators: DOT
vocabulary_token_kinds: DocComment, DocBlockComment, String

=== semantics
# Import dependency
on ImportDecl {
  edge moduleDependsOn from $file to $resolve($path) attrs obj("via", $path, "dep_kind", "value")
}

# Public declarations (vis:Visibility? in grammar — Visibility = public | open)
on ClassDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Class", "doc", $doc)
}
on StructDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Struct", "doc", $doc)
}
on EnumDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Enum", "doc", $doc)
}
on ProtocolDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Protocol", "doc", $doc)
}
on ActorDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Actor", "doc", $doc)
}
on FuncDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Function", "doc", $doc)
}
on VarDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Variable", "doc", $doc)
}
on TypeAliasDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "TypeAlias", "doc", $doc)
}

=== resolver
relative_prefixes: ./
module_path_style: dot
resolve:
  - manifest: Package.swift @ dependencies
  - marker: Package.swift
  - ext: .swift
  - fallback: spm:
