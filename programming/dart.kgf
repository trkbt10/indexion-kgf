kgf 0.6
language: dart
sources: .dart

=== lex
SKIP /[ \t]+/
TOKEN NL /\r?\n/

# Comments - Dart uses /// for documentation
TOKEN DocComment /\/\/\/(.*)/
TOKEN LineComment /\/\/[^\r\n]*/
TOKEN BlockComment /\/\*[\s\S]*?\*\//

# String literals
TOKEN String /'([^'\\]|\\.)*'|"([^"\\]|\\.)*"|'''[\s\S]*?'''|"""[\s\S]*?"""|r'[^']*'|r"[^"]*"/

# Numeric literals
TOKEN Number /0x[0-9a-fA-F]+|[0-9]+(\.[0-9]+)?([eE][+-]?[0-9]+)?/

# Annotations
TOKEN Annotation /@[a-zA-Z_][a-zA-Z0-9_]*/

# Keywords
KEYWORD KW_import   /import\b/
KEYWORD KW_export   /export\b/
KEYWORD KW_library  /library\b/
KEYWORD KW_part     /part\b/
KEYWORD KW_show     /show\b/
KEYWORD KW_hide     /hide\b/
KEYWORD KW_as       /as\b/
KEYWORD KW_deferred /deferred\b/
KEYWORD KW_class    /class\b/
KEYWORD KW_mixin    /mixin\b/
KEYWORD KW_extension /extension\b/
KEYWORD KW_enum     /enum\b/
KEYWORD KW_typedef  /typedef\b/
KEYWORD KW_abstract /abstract\b/
KEYWORD KW_sealed   /sealed\b/
KEYWORD KW_base     /base\b/
KEYWORD KW_interface /interface\b/
KEYWORD KW_final    /final\b/
KEYWORD KW_const    /const\b/
KEYWORD KW_var      /var\b/
KEYWORD KW_late     /late\b/
KEYWORD KW_static   /static\b/
KEYWORD KW_external /external\b/
KEYWORD KW_factory  /factory\b/
KEYWORD KW_extends  /extends\b/
KEYWORD KW_implements /implements\b/
KEYWORD KW_with     /with\b/
KEYWORD KW_get      /get\b/
KEYWORD KW_set      /set\b/
KEYWORD KW_operator /operator\b/
KEYWORD KW_if       /if\b/
KEYWORD KW_else     /else\b/
KEYWORD KW_switch   /switch\b/
KEYWORD KW_case     /case\b/
KEYWORD KW_for      /for\b/
KEYWORD KW_in       /in\b/
KEYWORD KW_while    /while\b/
KEYWORD KW_return   /return\b/
KEYWORD KW_async    /async\b/
KEYWORD KW_await    /await\b/
KEYWORD KW_on       /on\b/
KEYWORD KW_super    /super\b/

# Built-in types and values
TOKEN KeywordType /\b(?:void|dynamic|Function|Never|Object)\b/
TOKEN BoolLit /\b(?:true|false)\b/
TOKEN NullLit /\bnull\b/
TOKEN ThisLit /\bthis\b/
TOKEN SuperLit /\bsuper\b/

# Identifiers
TOKEN TypeIdent /[A-Z][a-zA-Z0-9_]*/
TOKEN Ident /[a-z_][a-zA-Z0-9_]*/

# Operators
TOKEN ARROW    /=>/
TOKEN NULLCOND /\?\./
TOKEN NULLCOAL /\?\?/
TOKEN CASCADE  /\.\./
TOKEN LT       /</
TOKEN GT       />/
TOKEN Operator /[+\-*\/%&|^~!=]+|&&|\|\|/

# Punctuation
TOKEN LBRACE   /\{/
TOKEN RBRACE   /\}/
TOKEN LPAREN   /\(/
TOKEN RPAREN   /\)/
TOKEN LBRACKET /\[/
TOKEN RBRACKET /\]/
TOKEN SEMI     /;/
TOKEN COMMA    /,/
TOKEN DOT      /\./
TOKEN COLON    /:/
TOKEN QMARK    /\?/
TOKEN AT       /@/

=== grammar
Module -> Item*

Item -> NL
     / LibraryDecl
     / ImportDecl
     / ExportDecl
     / PartDecl
     / ClassDecl
     / MixinDecl
     / ExtensionDecl
     / EnumDecl
     / TypedefDecl
     / FunctionDecl
     / VarDecl
     / DocComment
     / Other

# Doc block (consecutive /// comments)
DocBlock -> DocComment ( NL DocComment )*

# Library declaration
LibraryDecl -> KW_library QualifiedName SEMI
QualifiedName -> Ident ( DOT Ident )*

# Import/export declaration
ImportDecl -> KW_import path:String ( KW_deferred )? ( KW_as Ident )? Combinators? SEMI
ExportDecl -> KW_export path:String Combinators? SEMI
Combinators -> ( KW_show / KW_hide ) Ident ( COMMA Ident )*
PartDecl -> KW_part String SEMI

# Class declaration
ClassDecl -> doc:DocBlock? NL? Annotation* Modifier* KW_class id:TypeIdent TypeParams? ExtendsClause? ImplementsClause? WithClause? ClassBody
ExtendsClause -> KW_extends Type
ImplementsClause -> KW_implements TypeList
WithClause -> KW_with TypeList
ClassBody -> LBRACE ClassMember* RBRACE
ClassMember -> ConstructorDecl / MethodDecl / FieldDecl / GetterDecl / SetterDecl / OperatorDecl / ClassDecl / EnumDecl / NL / LineComment / BlockComment

# Mixin declaration
MixinDecl -> doc:DocBlock? NL? Annotation* KW_mixin id:TypeIdent TypeParams? ( KW_on TypeList )? ImplementsClause? MixinBody
MixinBody -> LBRACE MixinMember* RBRACE
MixinMember -> MethodDecl / FieldDecl / GetterDecl / SetterDecl / NL / LineComment / BlockComment

# Extension declaration
ExtensionDecl -> doc:DocBlock? NL? Annotation* KW_extension id:TypeIdent? TypeParams? KW_on Type ExtensionBody
ExtensionBody -> LBRACE ExtensionMember* RBRACE
ExtensionMember -> MethodDecl / GetterDecl / SetterDecl / OperatorDecl / NL / LineComment / BlockComment

# Enum declaration
EnumDecl -> doc:DocBlock? NL? Annotation* KW_enum id:TypeIdent ImplementsClause? WithClause? EnumBody
EnumBody -> LBRACE EnumValue* ( SEMI ClassMember* )? RBRACE
EnumValue -> value_doc:DocBlock? Annotation* value_id:Ident ( LPAREN ( Expr ( COMMA Expr )* )? RPAREN )? COMMA?

# Typedef declaration
TypedefDecl -> doc:DocBlock? NL? KW_typedef id:TypeIdent TypeParams? Operator Type SEMI

# Constructor declaration
ConstructorDecl -> doc:DocBlock? NL? Annotation* Modifier* TypeIdent ( DOT id:Ident )? LPAREN ParamList? RPAREN ( COLON InitializerList )? ( Body / ARROW Expr SEMI / SEMI )
InitializerList -> Initializer ( COMMA Initializer )*
Initializer -> ( KW_super / ThisLit ) ( DOT Ident )? LPAREN ( Expr ( COMMA Expr )* )? RPAREN / Ident Operator Expr

# Method declaration
MethodDecl -> doc:DocBlock? NL? Annotation* Modifier* Type? method_id:Ident TypeParams? LPAREN ParamList? RPAREN ( KW_async )? ( Body / ARROW Expr SEMI / SEMI )

# Field declaration
FieldDecl -> doc:DocBlock? NL? Annotation* Modifier* Type field_id:Ident ( Operator Expr )? SEMI

# Getter/Setter declaration
GetterDecl -> doc:DocBlock? NL? Annotation* Modifier* Type? KW_get getter_id:Ident ( Body / ARROW Expr SEMI / SEMI )
SetterDecl -> doc:DocBlock? NL? Annotation* Modifier* KW_set setter_id:Ident LPAREN Param RPAREN ( Body / ARROW Expr SEMI / SEMI )

# Operator declaration
OperatorDecl -> doc:DocBlock? NL? Annotation* Modifier* Type KW_operator Operator LPAREN ParamList? RPAREN ( Body / ARROW Expr SEMI )

# Top-level function declaration
FunctionDecl -> doc:DocBlock? NL? Annotation* Type? func_id:Ident TypeParams? LPAREN ParamList? RPAREN ( KW_async )? ( Body / ARROW Expr SEMI / SEMI )

# Top-level variable declaration
VarDecl -> doc:DocBlock? NL? Annotation* Modifier* Type var_id:Ident ( Operator Expr )? SEMI

# Modifiers
Modifier -> KW_abstract / KW_sealed / KW_base / KW_interface / KW_final / KW_const / KW_var / KW_late / KW_static / KW_external / KW_factory

# Parameters
ParamList -> Param ( COMMA Param )* / OptionalParams / NamedParams
Param -> NL* Annotation* ( Ident ( ThisLit DOT / SuperLit DOT ) param_id:Ident / ( KW_final / KW_var / KW_const )? Type? ( ThisLit DOT / SuperLit DOT )? param_id:Ident ) ( Operator Expr )?
OptionalParams -> LBRACKET Param ( COMMA Param )* RBRACKET
NamedParams -> LBRACE Param ( COMMA Param )* COMMA? NL* RBRACE

# Types
TypeParams -> LT TypeParam ( COMMA TypeParam )* GT
TypeParam -> TypeIdent ( KW_extends Type )?
TypeList -> Type ( COMMA Type )*
Type -> TypeAtom ( Operator TypeAtom )* QMARK?
TypeAtom -> TypeIdent TypeArgs? / Ident / KeywordType / LPAREN Type RPAREN / LPAREN TypeList RPAREN ARROW Type
TypeArgs -> LT Type ( COMMA Type )* GT
# Body (simplified - balance braces)
Body -> LBRACE BodyContent* RBRACE
BodyContent -> LBRACE BodyContent* RBRACE / LPAREN BodyContent* RPAREN / LBRACKET BodyContent* RBRACKET / Atom

# Expressions
Expr -> ExprAtom+
ExprAtom -> Ident / TypeIdent / Number / String / BoolLit / NullLit / ThisLit / SuperLit / KeywordType / KW_const / KW_as / KW_await / LPAREN / RPAREN / DOT / CASCADE / ARROW / NULLCOND / NULLCOAL / LT / GT / Operator / Annotation

Atom -> ExprAtom / NL / DocComment / LineComment / BlockComment / KW_import / KW_export / KW_library / KW_part / KW_show / KW_hide / KW_as / KW_deferred / KW_class / KW_mixin / KW_extension / KW_enum / KW_typedef / KW_abstract / KW_sealed / KW_base / KW_interface / KW_final / KW_const / KW_var / KW_late / KW_static / KW_external / KW_factory / KW_extends / KW_implements / KW_with / KW_get / KW_set / KW_operator / KW_if / KW_else / KW_switch / KW_case / KW_for / KW_in / KW_while / KW_return / KW_async / KW_await / KW_on / KW_super / SEMI / COMMA / COLON / QMARK / AT

Other -> Atom

=== attrs
on ClassDecl:     def id kind=Class doc=doc
on MixinDecl:     def id kind=Mixin doc=doc
on ExtensionDecl: def id kind=Extension doc=doc
on EnumDecl:      def id kind=Enum doc=doc
on TypedefDecl:   def id kind=Typedef doc=doc
on FunctionDecl:  def func_id kind=Function doc=doc
on MethodDecl:    def method_id kind=Method doc=doc
on FieldDecl:     def field_id kind=Field doc=doc
on GetterDecl:    def getter_id kind=Getter doc=doc
on SetterDecl:    def setter_id kind=Setter doc=doc
on VarDecl:       def var_id kind=Variable doc=doc
on EnumValue:     def value_id kind=EnumValue doc=value_doc
on Param:         def param_id kind=Param

on ImportDecl:    import module=path

=== features
function_kinds: Function
identifier_kinds: Ident, TypeIdent
qualifier_separators: DOT

=== semantics
# Import dependency
on ImportDecl {
  edge moduleDependsOn from $file to $resolve($path) attrs obj("via", $path, "dep_kind", "value")
}

# Dart top-level declarations
# In Dart, names starting with _ are library-private.
on ClassDecl when not(eq(slice($id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Class", "doc", $doc)
}
on MixinDecl when not(eq(slice($id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Mixin", "doc", $doc)
}
on ExtensionDecl when not(eq(slice($id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Extension", "doc", $doc)
}
on EnumDecl when not(eq(slice($id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Enum", "doc", $doc)
}
on TypedefDecl when not(eq(slice($id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Typedef", "doc", $doc)
}
on FunctionDecl when not(eq(slice($func_id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $func_id) attrs obj("name", $func_id, "kind", "Function", "doc", $doc)
}
on VarDecl when not(eq(slice($var_id, 0, 1), "_")) {
  edge declares from $file to concat($file, "::", $var_id) attrs obj("name", $var_id, "kind", "Variable", "doc", $doc)
}

# Method in class
on MethodDecl when $scope("value", "current_class") {
  let parent = $scope("value", "current_class")
  let sym_id = concat(parent, ".", $method_id)
  edge declares from parent to sym_id attrs obj("name", $method_id, "kind", "Method", "doc", $doc)
}

# Field in class
on FieldDecl when $scope("value", "current_class") {
  let parent = $scope("value", "current_class")
  let sym_id = concat(parent, ".", $field_id)
  edge declares from parent to sym_id attrs obj("name", $field_id, "kind", "Field", "doc", $doc)
}

# Enum value
on EnumValue when $scope("value", "current_enum") {
  let parent = $scope("value", "current_enum")
  let sym_id = concat(parent, ".", $value_id)
  edge declares from parent to sym_id attrs obj("name", $value_id, "kind", "EnumValue", "doc", $value_doc)
}

=== resolver
relative_prefixes: ./
module_path_style: slash
resolve:
  - manifest: pubspec.yaml @ dependencies
  - ext: .dart
  - fallback: pub:
