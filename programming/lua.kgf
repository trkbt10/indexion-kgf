kgf 0.6
language: lua
sources: .lua

=== lex
SKIP /[ \t]+/
TOKEN NL /\r?\n/

# Comments - block must precede line to avoid --[[ matching --
TOKEN DocComment /---(.*)/
TOKEN BlockComment /--\[\[[\s\S]*?\]\]/
TOKEN LineComment /--[^\r\n]*/

# String literals
TOKEN String /"([^"\\]|\\.)*"|'([^'\\]|\\.)*'|\[\[[\s\S]*?\]\]|\[=\[[\s\S]*?\]=\]/

# Numeric literals
TOKEN Number /0x[0-9a-fA-F]+|[0-9]+(\.[0-9]+)?([eE][+-]?[0-9]+)?/

# Keywords
KEYWORD KW_function /function\b/
KEYWORD KW_local    /local\b/
KEYWORD KW_end      /end\b/
KEYWORD KW_return   /return\b/
KEYWORD KW_if       /if\b/
KEYWORD KW_then     /then\b/
KEYWORD KW_elseif   /elseif\b/
KEYWORD KW_else     /else\b/
KEYWORD KW_for      /for\b/
KEYWORD KW_in       /in\b/
KEYWORD KW_while    /while\b/
KEYWORD KW_do       /do\b/
KEYWORD KW_repeat   /repeat\b/
KEYWORD KW_until    /until\b/
KEYWORD KW_break    /break\b/

# Built-in values
TOKEN BoolLit /\b(?:true|false)\b/
TOKEN NilLit /\bnil\b/

# Identifiers
TOKEN Ident /[a-zA-Z_][a-zA-Z0-9_]*/

# Operators
TOKEN Operator /[+\-*\/%^#<>=~]+|\.\.\.?|==|~=|<=|>=|<<|>>|\/\/|&|\||~/

# Punctuation
TOKEN LBRACE   /\{/
TOKEN RBRACE   /\}/
TOKEN LPAREN   /\(/
TOKEN RPAREN   /\)/
TOKEN LBRACKET /\[/
TOKEN RBRACKET /\]/
TOKEN SEMI     /;/
TOKEN COMMA    /,/
TOKEN DOT      /\./
TOKEN COLON    /:/
TOKEN EQ       /=/

=== grammar
Module -> Item*

Item -> NL
     / DocComment
     / FunctionDecl
     / LocalFunctionDecl
     / LocalVarDecl
     / AssignmentDecl
     / Other

# Doc block
DocBlock -> DocComment ( NL DocComment )*

# Function declaration (global)
FunctionDecl -> doc:DocBlock? NL? KW_function id:FunctionName LPAREN ParamList? RPAREN FunctionBody KW_end
FunctionName -> Ident ( DOT Ident )* ( COLON Ident )?

# Local function declaration
LocalFunctionDecl -> doc:DocBlock? NL? KW_local KW_function id:Ident LPAREN ParamList? RPAREN FunctionBody KW_end

# Local variable declaration
LocalVarDecl -> doc:DocBlock? NL? KW_local id:Ident ( COMMA Ident )* ( EQ ExprList )?

# Global assignment (can define functions too)
AssignmentDecl -> doc:DocBlock? NL? id:Ident ( DOT Ident )* EQ Expr

# Function body
FunctionBody -> ( Statement )*
Statement -> NL / LineComment / BlockComment / KW_if / KW_then / KW_elseif / KW_else / KW_for / KW_in / KW_while / KW_do / KW_repeat / KW_until / KW_break / KW_return / Expr

# Parameters
ParamList -> Param ( COMMA Param )*
Param -> param_id:Ident / Operator

# Expression list
ExprList -> Expr ( COMMA Expr )*

# Expressions
Expr -> ExprAtom+
ExprAtom -> Ident / Number / String / BoolLit / NilLit / LPAREN / RPAREN / LBRACE / RBRACE / LBRACKET / RBRACKET / DOT / COMMA / COLON / EQ / Operator

Atom -> ExprAtom / NL / DocComment / LineComment / BlockComment / KW_function / KW_local / KW_end / KW_return / KW_if / KW_then / KW_elseif / KW_else / KW_for / KW_in / KW_while / KW_do / KW_repeat / KW_until / KW_break / SEMI

Other -> Atom

=== attrs
on FunctionDecl:      def id kind=Function doc=doc
on LocalFunctionDecl: def id kind=Function doc=doc
on LocalVarDecl:      def id kind=Variable doc=doc
on AssignmentDecl:    def id kind=Variable doc=doc
on Param:             def param_id kind=Param

=== features
function_kinds: Function
function_keyword: KW_function
identifier_kinds: Ident

=== semantics
# Lua public declarations
# FunctionDecl = global function (public), LocalFunctionDecl = local (private)
on FunctionDecl {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Function", "doc", $doc)
}
# Global assignments are module-level exports
on AssignmentDecl {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Variable", "doc", $doc)
}

=== resolver
relative_prefixes: ./
module_path_style: dot
resolve:
  - manifest: *.rockspec @ dependencies
  - marker: *.rockspec, .luacheckrc
  - ext: .lua
  - index: /init.lua
  - fallback: luarocks:
