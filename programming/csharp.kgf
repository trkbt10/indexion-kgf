kgf 0.6
language: csharp
sources: .cs

=== lex
SKIP /[ \t]+/
TOKEN NL /\r?\n/

# Comments - C# uses /// for XML documentation
TOKEN DocComment /\/\/\/(.*)/
TOKEN LineComment /\/\/[^\r\n]*/
TOKEN BlockComment /\/\*[\s\S]*?\*\//

# String literals
TOKEN String /"([^"\\]|\\.)*"|@"[^"]*"|$"([^"\\{]|\\.|\\{[^}]*\\})*"/
TOKEN Char /'([^'\\]|\\.)*'/

# Numeric literals
TOKEN Number /0x[0-9a-fA-F]+|0b[01]+|[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[fFdDmMlLuU]*/

# Keywords
KEYWORD KW_namespace /namespace\b/
KEYWORD KW_using     /using\b/
KEYWORD KW_class     /class\b/
KEYWORD KW_struct    /struct\b/
KEYWORD KW_interface /interface\b/
KEYWORD KW_enum      /enum\b/
KEYWORD KW_record    /record\b/
KEYWORD KW_delegate  /delegate\b/
KEYWORD KW_public    /public\b/
KEYWORD KW_private   /private\b/
KEYWORD KW_protected /protected\b/
KEYWORD KW_internal  /internal\b/
KEYWORD KW_static    /static\b/
KEYWORD KW_abstract  /abstract\b/
KEYWORD KW_sealed    /sealed\b/
KEYWORD KW_partial   /partial\b/
KEYWORD KW_virtual   /virtual\b/
KEYWORD KW_override  /override\b/
KEYWORD KW_new       /new\b/
KEYWORD KW_readonly  /readonly\b/
KEYWORD KW_const     /const\b/
KEYWORD KW_async     /async\b/
KEYWORD KW_await     /await\b/
KEYWORD KW_void      /void\b/
KEYWORD KW_return    /return\b/
KEYWORD KW_if        /if\b/
KEYWORD KW_else      /else\b/
KEYWORD KW_switch    /switch\b/
KEYWORD KW_case      /case\b/
KEYWORD KW_for       /for\b/
KEYWORD KW_foreach   /foreach\b/
KEYWORD KW_while     /while\b/
KEYWORD KW_in        /in\b/
KEYWORD KW_out       /out\b/
KEYWORD KW_ref       /ref\b/
KEYWORD KW_get       /get\b/
KEYWORD KW_set       /set\b/
KEYWORD KW_init      /init\b/
KEYWORD KW_value     /value\b/
KEYWORD KW_this      /this\b/
KEYWORD KW_base      /base\b/
KEYWORD KW_where     /where\b/
KEYWORD KW_event     /event\b/

# Built-in types
TOKEN KeywordType /\b(?:void|int|byte|sbyte|short|ushort|long|ulong|float|double|decimal|bool|char|string|object|dynamic|var)\b/

# Built-in values
TOKEN BoolLit /\b(?:true|false)\b/
TOKEN NullLit /\bnull\b/

# Identifiers
TOKEN TypeIdent /[A-Z][a-zA-Z0-9_]*/
TOKEN Ident /[a-z_@][a-zA-Z0-9_]*/

# Operators
TOKEN ARROW    /=>/
TOKEN NULLCOND /\?\./
TOKEN NULLCOAL /\?\?/
TOKEN LT       /</
TOKEN GT       />/
TOKEN Operator /[+\-*%&|^~!=]+|&&|\|\||<<|>>/

# Punctuation
TOKEN LBRACE   /\{/
TOKEN RBRACE   /\}/
TOKEN LPAREN   /\(/
TOKEN RPAREN   /\)/
TOKEN LBRACKET /\[/
TOKEN RBRACKET /\]/
TOKEN SEMI     /;/
TOKEN COMMA    /,/
TOKEN DOT      /\./
TOKEN QMARK    /\?/
TOKEN COLON    /:/

# Additional keywords used in grammar contexts
KEYWORD KW_extern /extern\b/
KEYWORD KW_unsafe /unsafe\b/

=== grammar
Module -> Item*

Item -> NL
     / UsingDecl
     / NamespaceDecl
     / ClassDecl
     / StructDecl
     / InterfaceDecl
     / EnumDecl
     / RecordDecl
     / DelegateDecl
     / DocComment
     / Other

# Doc block (consecutive /// comments)
DocBlock -> DocComment ( NL DocComment )*

# Using declaration
UsingDecl -> KW_using KW_static? ( Ident Operator )? path:QualifiedName SEMI
QualifiedName -> ( Ident / TypeIdent ) ( DOT ( Ident / TypeIdent ) )*

# Namespace declaration
NamespaceDecl -> KW_namespace QualifiedName NL? ( NamespaceBody / SEMI )
NamespaceBody -> LBRACE NamespaceMember* RBRACE
NamespaceMember -> UsingDecl / NamespaceDecl / ClassDecl / StructDecl / InterfaceDecl / EnumDecl / RecordDecl / DelegateDecl / NL / LineComment / BlockComment

# Class declaration
ClassDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* KW_partial? KW_class id:TypeIdent TypeParams? BaseList? WhereClause? NL? LBRACE ClassMember* RBRACE
BaseList -> COLON TypeList
ClassMember -> ConstructorDecl / MethodDecl / PropertyDecl / FieldDecl / EventDecl / IndexerDecl / ClassDecl / StructDecl / InterfaceDecl / EnumDecl / DelegateDecl / NL / LineComment / BlockComment

# Struct declaration
StructDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* KW_partial? KW_readonly? KW_struct id:TypeIdent TypeParams? BaseList? WhereClause? NL? StructBody
StructBody -> LBRACE StructMember* RBRACE
StructMember -> ConstructorDecl / MethodDecl / PropertyDecl / FieldDecl / EventDecl / IndexerDecl / ClassDecl / StructDecl / InterfaceDecl / EnumDecl / DelegateDecl / NL / LineComment / BlockComment

# Interface declaration
InterfaceDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* KW_partial? KW_interface id:TypeIdent TypeParams? BaseList? WhereClause? NL? InterfaceBody
InterfaceBody -> LBRACE InterfaceMember* RBRACE
InterfaceMember -> MethodDecl / PropertyDecl / EventDecl / IndexerDecl / NL / LineComment / BlockComment

# Enum declaration
EnumDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* KW_enum id:TypeIdent ( COLON Type )? NL? EnumBody
EnumBody -> LBRACE EnumMember* RBRACE
EnumMember -> member_doc:DocBlock? Attribute* member_id:Name ( Operator Expr )? COMMA? / NL / LineComment / BlockComment

# Record declaration
RecordDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* KW_partial? KW_record KW_struct? KW_class? id:TypeIdent TypeParams? RecordParams? BaseList? WhereClause? ( RecordBody / SEMI )
RecordParams -> LPAREN ParamList? RPAREN
RecordBody -> LBRACE ClassMember* RBRACE

# Delegate declaration
DelegateDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* KW_delegate Type id:TypeIdent TypeParams? LPAREN ParamList? RPAREN WhereClause? SEMI

# Constructor declaration
ConstructorDecl -> doc:DocBlock? NL? Attribute* Modifier* id:TypeIdent LPAREN ParamList? RPAREN ( COLON ( KW_this / KW_base ) LPAREN ( Expr ( COMMA Expr )* )? RPAREN )? NL? Body

# Method declaration
Name -> Ident / TypeIdent
MethodDecl -> doc:DocBlock? NL? Attribute* vis:KW_public? Modifier* Type method_id:Name TypeParams? LPAREN ParamList? RPAREN WhereClause? NL? ( Body / ARROW Expr SEMI / SEMI )

# Property declaration
PropertyDecl -> doc:DocBlock? NL? Attribute* Modifier* Type prop_id:Name ( PropertyAccessors / ARROW Expr SEMI )
PropertyAccessors -> LBRACE Accessor+ RBRACE ( Operator Expr SEMI )?
Accessor -> Attribute* Modifier* ( KW_get / KW_set / KW_init ) ( Body / SEMI / ARROW Expr SEMI )

# Field declaration
FieldDecl -> doc:DocBlock? NL? Attribute* Modifier* Type field_id:Name ( Operator Expr )? SEMI

# Event declaration
EventDecl -> doc:DocBlock? NL? Attribute* Modifier* KW_event Type event_id:Ident ( EventAccessors / ( Operator Expr )? SEMI )
EventAccessors -> LBRACE EventAccessor+ RBRACE
EventAccessor -> Attribute* ( Ident ) Body

# Indexer declaration
IndexerDecl -> doc:DocBlock? NL? Attribute* Modifier* Type KW_this LBRACKET ParamList RBRACKET PropertyAccessors

# Attributes
Attribute -> LBRACKET Ident ( COLON )? ( Ident / TypeIdent ) ( LPAREN ( Expr ( COMMA Expr )* )? RPAREN )? RBRACKET

# Modifiers
Modifier -> KW_public / KW_private / KW_protected / KW_internal / KW_static / KW_abstract / KW_sealed / KW_partial / KW_virtual / KW_override / KW_new / KW_readonly / KW_const / KW_async / KW_extern / KW_unsafe

# Parameters
ParamList -> Param ( COMMA Param )*
Param -> Attribute* ( KW_this / KW_ref / KW_out / KW_in )? Type param_id:Ident ( Operator Expr )?
WhereClause -> KW_where TypeIdent COLON TypeConstraint ( COMMA TypeConstraint )*
TypeConstraint -> Type / KW_class / KW_struct / KW_new LPAREN RPAREN

# Types
TypeParams -> LT TypeParam ( COMMA TypeParam )* GT
TypeParam -> Attribute* ( KW_in / KW_out )? TypeIdent
TypeList -> Type ( COMMA Type )*
Type -> TypeAtom ArrayDims? QMARK? / LPAREN TupleElement ( COMMA TupleElement )+ RPAREN
TypeAtom -> QualifiedName TypeArgs? / KeywordType / KW_void
TypeArgs -> LT Type ( COMMA Type )* GT
ArrayDims -> LBRACKET RBRACKET
TupleElement -> Type Ident?
# Body (simplified - balance braces)
Body -> LBRACE BodyContent* RBRACE
BodyContent -> LBRACE BodyContent* RBRACE / LPAREN BodyContent* RPAREN / LBRACKET BodyContent* RBRACKET / Atom

# Expressions
Expr -> ExprAtom+
ExprAtom -> Ident / TypeIdent / Number / String / Char / BoolLit / NullLit / KeywordType / KW_new / KW_this / KW_base / LPAREN / RPAREN / DOT / COMMA / COLON / ARROW / NULLCOND / NULLCOAL / LT / GT / Operator

Atom -> Ident / TypeIdent / Number / String / Char / BoolLit / NullLit / KeywordType / NL / DocComment / LineComment / BlockComment / KW_namespace / KW_using / KW_class / KW_struct / KW_interface / KW_enum / KW_record / KW_delegate / KW_public / KW_private / KW_protected / KW_internal / KW_static / KW_abstract / KW_sealed / KW_partial / KW_virtual / KW_override / KW_new / KW_readonly / KW_const / KW_async / KW_await / KW_void / KW_return / KW_if / KW_else / KW_switch / KW_case / KW_for / KW_foreach / KW_while / KW_in / KW_out / KW_ref / KW_get / KW_set / KW_init / KW_value / KW_this / KW_base / KW_where / KW_event / KW_extern / KW_unsafe / SEMI / COMMA / COLON / DOT / QMARK / ARROW / NULLCOND / NULLCOAL / LT / GT / Operator

Other -> Atom

=== attrs
on ClassDecl:     def id kind=Class doc=doc
on StructDecl:    def id kind=Struct doc=doc
on InterfaceDecl: def id kind=Interface doc=doc
on EnumDecl:      def id kind=Enum doc=doc
on RecordDecl:    def id kind=Record doc=doc
on DelegateDecl:  def id kind=Delegate doc=doc
on MethodDecl:    def method_id kind=Method doc=doc vis=vis
on PropertyDecl:  def prop_id kind=Property doc=doc
on FieldDecl:     def field_id kind=Field doc=doc
on EventDecl:     def event_id kind=Event doc=doc
on ConstructorDecl: def id kind=Constructor doc=doc
on EnumMember:    def member_id kind=EnumMember doc=member_doc
on Param:         def param_id kind=Param

on UsingDecl:     import module=path

=== features
document_symbol_kinds: Class, Struct, Interface, Enum, Record, Delegate
function_kinds: Method
coverage_token_kinds: Ident, TypeIdent
identifier_kinds: Ident, TypeIdent

=== semantics
# Import dependency
on UsingDecl {
  edge moduleDependsOn from $file to $resolve($path) attrs obj("via", $path, "dep_kind", "value")
}

# Public declarations (vis:KW_public? in grammar)
on ClassDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Class", "doc", $doc)
}
on StructDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Struct", "doc", $doc)
}
on InterfaceDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Interface", "doc", $doc)
}
on EnumDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Enum", "doc", $doc)
}
on RecordDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Record", "doc", $doc)
}
on DelegateDecl when $vis {
  edge declares from $file to concat($file, "::", $id) attrs obj("name", $id, "kind", "Delegate", "doc", $doc)
}
on MethodDecl when $vis {
  edge declares from $file to concat($file, "::", $method_id) attrs obj("name", $method_id, "kind", "Method", "doc", $doc)
}

=== resolver
relative_prefixes: ./, ../
module_path_style: dot
resolve:
  - manifest: *.csproj @ ItemGroup/PackageReference
  - manifest: packages.config @ packages
  - manifest: Directory.Build.props @ PackageReference
  - marker: *.csproj, *.sln, Directory.Build.props
  - ext: .cs
  - fallback: nuget:
